//
// Windows version resource. Configured by CMake from the VERSION file
// in this directory; values are visible in Explorer via right-click →
// Properties → Details on gateway.exe.

#include <winver.h>

1 VERSIONINFO
FILEVERSION    @GATEWAY_VERSION_MAJOR@,@GATEWAY_VERSION_MINOR@,@GATEWAY_VERSION_PATCH@,0
PRODUCTVERSION @GATEWAY_VERSION_MAJOR@,@GATEWAY_VERSION_MINOR@,@GATEWAY_VERSION_PATCH@,0
FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
FILEFLAGS      0
FILEOS         VOS_NT_WINDOWS32
FILETYPE       VFT_APP
FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "The Fletcher Authors"
            VALUE "FileDescription",  "Fletcher WebSocket Gateway"
            VALUE "FileVersion",      "@GATEWAY_VERSION_FULL@"
            VALUE "InternalName",     "gateway"
            VALUE "LegalCopyright",   "Copyright (C) 2026 The Fletcher Authors. LGPL-3.0-or-later."
            VALUE "OriginalFilename", "gateway.exe"
            VALUE "ProductName",      "Fletcher"
            VALUE "ProductVersion",   "@GATEWAY_VERSION_FULL@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
