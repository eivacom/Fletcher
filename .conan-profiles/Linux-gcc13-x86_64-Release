[settings]
arch=x86_64
build_type=Release
compiler=gcc
compiler.cppstd=gnu20
compiler.libcxx=libstdc++11
compiler.version=13
os=Linux
[options]
# No blanket *:shared here — shared/static is each recipe's own option/default
# (see the per-component conanfiles). Opt into an all-shared build by layering
# the composable `shared` profile fragment: -pr:a=<this> -pr:a=shared.
# The b2 entries below are build-tool/env config for building Boost, not policy.
b2/*:toolset=cxx
b2/*:use_cxx_env=True